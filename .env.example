# Hermes — Environment Variables
# Local: copy to .env  |  Railway: set under Settings → Variables

# ── Required ──────────────────────────────────────────────────────────────────

# Tavily search (free key at tavily.com)
TAVILY_API_KEY=tvly-...

# Ollama host — REQUIRED for Railway / cloud deploy
# Local Mac:          http://127.0.0.1:11434   (default, no need to set)
# Mac via ngrok:      https://xxxx.ngrok-free.app
# Cloud VM:           http://<server-ip>:11434
# NOTE: CrewAI's native Ollama provider reads this var directly.
OLLAMA_HOST=http://127.0.0.1:11434

# ── Optional tuning ───────────────────────────────────────────────────────────
STALL_TIMEOUT=600        # seconds before watchdog triggers (10 min)
STALL_MAX_RETRIES=1      # retries on stall; auto-falls back to e4b model
