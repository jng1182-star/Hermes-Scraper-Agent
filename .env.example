# Hermes — Competitive Intelligence
# Ensure Ollama is running: ollama serve
# Pull models: ollama pull gemma4:e4b && ollama pull gemma4:26b

# Tavily search (primary scraper — get key at tavily.com)
TAVILY_API_KEY=tvly-...

# Tuning (optional)
STALL_TIMEOUT=180        # seconds before watchdog triggers
STALL_MAX_RETRIES=2      # retries on stall before aborting
