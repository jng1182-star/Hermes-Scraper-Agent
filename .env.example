# Hermes — Environment Variables
# Local: copy to .env  |  Railway: set under Settings → Variables

# ── Required ──────────────────────────────────────────────────────────────────

# No external web search API key required — uses DuckDuckGo search

# Ollama host — REQUIRED for Railway / cloud deploy
# Local Mac:          http://127.0.0.1:11434   (default, no need to set)
# Mac via ngrok:      https://xxxx.ngrok-free.app
# Cloud VM:           http://<server-ip>:11434
# NOTE: CrewAI's native Ollama provider reads this var directly.
OLLAMA_HOST=http://127.0.0.1:11434

# Token required by ollama_proxy.py when tunnelling via ngrok.
HERMES_TUNNEL_TOKEN=

# ── Anti-Detect Browser (required for Instagram + TikTok feed scraping) ───────
# Instagram and TikTok FYP feeds require pre-warmed authenticated browser profiles
# to avoid bot-detection. Connect your anti-detect browser provider here.
#
# Supported providers: gologin | adspower | multilogin
# GoLogin:    API key from app.gologin.com → Settings → API
# AdsPower:   Local API, no key needed (runs on localhost:50325 by default)
# Multilogin: API key from app.multiloginapp.com → Profile → API key
#
ANTIDETECT_PROVIDER=gologin
ANTIDETECT_API_KEY=
#
# Pre-warmed profile IDs — one per market. Create profiles in your anti-detect browser,
# warm them by browsing normally for 1–2 days, then paste the profile IDs below.
# The profile must have the target market's residential proxy already configured inside it.
ANTIDETECT_PROFILE_PH=
ANTIDETECT_PROFILE_TH=
ANTIDETECT_PROFILE_VN=
ANTIDETECT_PROFILE_ID=
ANTIDETECT_PROFILE_MY=
ANTIDETECT_PROFILE_SG=
ANTIDETECT_PROFILE_DEFAULT=    # fallback for markets without a dedicated profile
#
# AdsPower only: override local API URL if running on a non-default port
# ADSPOWER_LOCAL_URL=http://local.adspower.net:50325

# ── TikTok Official API (for paid ad library access) ─────────────────────────
# Optional — enables TikTok Ad Library historical data (run dates, cumulative spend).
# Without these, paid TikTok data comes from in-feed DOM detection only (Agent 2).
# Obtain from TikTok for Developers portal: developers.tiktok.com
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# ── Meta Graph API (for Meta Ad Library access) ───────────────────────────────
# Required for Facebook/Instagram ad library scraping.
META_AD_LIBRARY_TOKEN=

# ── Geo Residential Proxies (recommended for SEA market accuracy) ─────────────
# Social platforms serve geo-targeted ads based on requesting IP geolocation.
# Without these, the scraper will see ads served to its own egress country (e.g. SG/US),
# NOT the target market. This directly affects data accuracy for paid ad intelligence.
#
# Format: <scheme>://username:password@host:port
# Supported schemes: http, https, socks5
# Provider examples: Bright Data, Oxylabs, Smartproxy, IPRoyal
#
# The system degrades gracefully without proxies (warning logged, no crash),
# but a data quality caveat is written into the report's assumptions block.
#
PROXY_TH=socks5://user:pass@th-exit.provider.com:1080
PROXY_PH=socks5://user:pass@ph-exit.provider.com:1080
PROXY_VN=socks5://user:pass@vn-exit.provider.com:1080
PROXY_ID=socks5://user:pass@id-exit.provider.com:1080
PROXY_MY=socks5://user:pass@my-exit.provider.com:1080
PROXY_SG=socks5://user:pass@sg-exit.provider.com:1080

# ── LLM routing — prevents accidental OpenAI API calls ───────────────────────
# CrewAI 1.14.x uses OpenAICompatibleCompletion for Ollama. If OPENAI_API_KEY is set to
# a real key, the SDK may route requests to api.openai.com → 403 Forbidden.
# Set these to keep all LLM traffic local.
OPENAI_API_KEY=ollama
OPENAI_API_BASE=http://127.0.0.1:11434/v1
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
CREWAI_TELEMETRY_OPT_OUT=true

# ── Optional tuning ───────────────────────────────────────────────────────────
STALL_TIMEOUT=600        # seconds before watchdog triggers (10 min)
STALL_MAX_RETRIES=1      # retries on stall; auto-falls back to e4b model
ANALYST_TIMEOUT=300      # per-phase hard cap (seconds)
REPORTER_TIMEOUT=180
GATE_TIMEOUT=120
