# Force all LLM traffic to local Ollama — prevents accidental ngrok/cloud routing
# OPENAI_API_KEY=ollama prevents CrewAI's OpenAICompatibleCompletion from falling back
# to a real OPENAI_API_KEY env var and routing requests to api.openai.com (→ 403 error).
OLLAMA_HOST=http://127.0.0.1:11434
OPENAI_API_KEY=ollama
OPENAI_API_BASE=http://127.0.0.1:11434/v1
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
CREWAI_TELEMETRY_OPT_OUT=true
